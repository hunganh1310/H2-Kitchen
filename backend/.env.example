# ------------------------------------------------------------------
# H2 Kitchen backend — environment variables
# Copy this file to `.env` and fill in real values.
# ------------------------------------------------------------------

# --- Database -----------------------------------------------------
# MongoDB connection string. Local: mongodb://localhost:27017
# Production: MongoDB Atlas SRV URI (mongodb+srv://user:pass@cluster.../)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=h2_kitchen

# --- Auth (JWT) ---------------------------------------------------
# Generate a strong secret, e.g.:  python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- External services (wired up in later roadmap steps) ----------
# Discord webhook for new-order notifications (step 6)
DISCORD_WEBHOOK_URL=
# Bank account info for VietQR generation (step 5) — e.g. "970422|123456789|NGUYEN VAN A"
BANK_ACCOUNT_INFO=
# Cloudinary for product images (step 2/admin) — either full URL or the 3 parts
CLOUDINARY_URL=
# SePay webhook key — auto-confirms VietQR transfers. Set the same value in the
# SePay dashboard (https://sepay.vn). Leave empty to disable the webhook.
SEPAY_WEBHOOK_API_KEY=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- CORS ---------------------------------------------------------
# Comma-separated list of allowed frontend origins.
# Add your Vercel domain here at deploy time.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Local dev conveniences --------------------------------------
# USE_MOCK_DB=true runs an in-memory MongoDB (no install needed). Keep false in prod.
USE_MOCK_DB=false
# Idempotently seed the 3 admin accounts on startup if missing.
SEED_ON_STARTUP=true
